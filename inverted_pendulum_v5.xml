<mujoco model="inverted pendulum">
 <compiler inertiafromgeom="true"/>
 <default>
  <joint armature="0" damping="1" limited="true"/>
  <geom contype="0" friction="1 0.1 0.1" rgba="0.7 0.7 0 1"/>
  <tendon/>
  <motor ctrlrange="-3 3"/>
 </default>
 <option gravity="0 0 -9.81" integrator="RK4" timestep="0.02"/>
 <size nstack="3000"/>
 <worldbody>
  <!--geom name="ground" type="plane" pos="0 0 0" /-->
  <geom name="rail_red" fromto="-100 0 0 -75 0 0" rgba="0.95 0.15 0.15 1" size="0.02" type="capsule"/>
  <geom name="rail_orange" fromto="-75 0 0 -50 0 0" rgba="1.0 0.55 0.05 1" size="0.02" type="capsule"/>
  <geom name="rail_yellow" fromto="-50 0 0 -25 0 0" rgba="0.95 0.85 0.05 1" size="0.02" type="capsule"/>
  <geom name="rail_green" fromto="-25 0 0 0 0 0" rgba="0.1 0.75 0.25 1" size="0.02" type="capsule"/>
  <geom name="rail_cyan" fromto="0 0 0 25 0 0" rgba="0.0 0.8 0.9 1" size="0.02" type="capsule"/>
  <geom name="rail_blue" fromto="25 0 0 50 0 0" rgba="0.1 0.3 1.0 1" size="0.02" type="capsule"/>
  <geom name="rail_purple" fromto="50 0 0 75 0 0" rgba="0.55 0.2 0.95 1" size="0.02" type="capsule"/>
  <geom name="rail_magenta" fromto="75 0 0 100 0 0" rgba="0.95 0.1 0.75 1" size="0.02" type="capsule"/>
  <geom name="rail_center_mark" fromto="-0.5 0 0.04 0.5 0 0.04" rgba="1 1 1 1" size="0.012" type="capsule"/>
  <body name="cart" pos="0 0 0">
   <joint axis="1 0 0" limited="true" name="slider" pos="0 0 0" range="-100 100" type="slide"/>
   <geom name="cart" pos="0 0 0" quat="0.707 0 0.707 0" size="0.1 0.1" type="capsule"/>
   <camera name="track_cart" mode="trackcom" pos="0 -4 1.2" xyaxes="1 0 0 0 0 1"/>
   <body name="pole" pos="0 0 0">
    <joint axis="0 1 0" limited="false" name="hinge" pos="0 0 0" type="hinge"/>
    <geom fromto="0 0 0 0.001 0 0.6" name="cpole" rgba="0 0.7 0.7 1" size="0.049 0.3" type="capsule"/>
    <!-- <body name="pole2" pos="0.001 0 0.6"><joint name="hinge2" type="hinge" pos="0 0 0" axis="0 1 0"/><geom name="cpole2" type="capsule" fromto="0 0 0 0 0 0.6" size="0.05 0.3" rgba="0.7 0 0.7 1"/><site name="tip2" pos="0 0 .6"/></body>-->
   </body>
  </body>
 </worldbody>
 <actuator>
  <motor ctrllimited="true" ctrlrange="-10 10" gear="100" joint="slider" name="slide"/>
 </actuator>
</mujoco>
